{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Production-Quality Personal Portfolio Website",
  "main": "server.js",
  "scripts": {
    "build": "node build.js && npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --minify",
    "dev": "concurrently \"npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch\" \"node build.js\""
  },
  "keywords": [
    "portfolio",
    "developer",
    "nodejs",
    "express"
  ],
