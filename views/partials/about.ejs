<section id="about" class="py-24 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16" data-aos="fade-up">
            <h2 class="font-poppins text-3xl md:text-5xl font-bold text-text-main mb-4">About <span class="text-accent-primary">Me</span></h2>
            <div class="w-24 h-1 bg-gradient-to-r from-accent-primary to-transparent mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            
            <!-- Left: Image Profile -->
            <div class="lg:col-span-5" data-aos="fade-right">
                <div class="relative group">
                    <div class="absolute -inset-1 bg-gradient-to-r from-accent-primary to-accent-secondary rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
                    <div class="relative rounded-2xl overflow-hidden aspect-square border border-border bg-card">
                        <img src="./public/images/profile.jpg" alt="Profile Image" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500" onerror="this.src='https://ui-avatars.com/api/?name=Tanjimul+Islam&size=512&background=09090B&color=06B6D4'">
                    </div>
                </div>
            </div>

            <!-- Right: Biography and Info -->
            <div class="lg:col-span-7" data-aos="fade-left">
                <h3 class="text-2xl font-poppins font-semibold mb-6 text-text-main">
                    <%= data.personal.subtitle %>
                </h3>
                
                <p class="text-text-muted text-lg leading-relaxed mb-8">
                    <%= data.personal.about %>
                </p>

                <!-- Quick Info Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="bg-card p-4 rounded-xl border border-border flex items-start gap-4 hover:border-accent-primary/30 transition-colors">
                        <div class="p-2 bg-accent-primary/10 text-accent-primary rounded-lg">
                            <i data-lucide="graduation-cap" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-sm text-text-muted">University</p>
                            <p class="font-medium text-text-main"><%= data.personal.university %> (<%= data.personal.department %>)</p>
                        </div>
                    </div>
                    
                    <div class="bg-card p-4 rounded-xl border border-border flex items-start gap-4 hover:border-accent-primary/30 transition-colors">
                        <div class="p-2 bg-accent-primary/10 text-accent-primary rounded-lg">
                            <i data-lucide="map-pin" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-sm text-text-muted">Location</p>
                            <p class="font-medium text-text-main"><%= data.personal.location %></p>
                        </div>
                    </div>
                    
                    <div class="bg-card p-4 rounded-xl border border-border flex items-start gap-4 hover:border-accent-primary/30 transition-colors">
                        <div class="p-2 bg-accent-primary/10 text-accent-primary rounded-lg">
                            <i data-lucide="mail" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-sm text-text-muted">Email</p>
                            <a href="mailto:<%= data.personal.email %>" class="font-medium text-text-main hover:text-accent-primary"><%= data.personal.email %></a>
                        </div>
                    </div>
                    
                    <div class="bg-card p-4 rounded-xl border border-border flex items-start gap-4 hover:border-accent-primary/30 transition-colors">
                        <div class="p-2 bg-accent-primary/10 text-accent-primary rounded-lg">
                            <i data-lucide="heart" class="w-6 h-6"></i>
                        </div>
                        <div>
                            <p class="text-sm text-text-muted">Interests</p>
                            <p class="font-medium text-text-main"><%= data.personal.interests %></p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
