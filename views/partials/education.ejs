<section id="education" class="py-24 relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16" data-aos="fade-up">
            <h2 class="font-poppins text-3xl md:text-5xl font-bold text-text-main mb-4">My <span class="text-accent-primary">Education</span></h2>
            <div class="w-24 h-1 bg-gradient-to-r from-accent-primary to-transparent mx-auto rounded-full"></div>
        </div>

        <div class="relative wrap overflow-hidden h-full">
            <!-- Timeline Vertical Line -->
            <div class="border-2-2 absolute border-opacity-20 border-accent-primary h-full border" style="left: 50%;"></div>
            
            <% data.education.forEach((edu, index) => { %>
                <div class="mb-12 flex justify-between items-center w-full <%= index % 2 === 0 ? 'flex-row-reverse left-timeline' : 'right-timeline' %>" data-aos="<%= index % 2 === 0 ? 'fade-left' : 'fade-right' %>">
                    <div class="order-1 w-5/12"></div>
                    
                    <div class="z-20 flex items-center order-1 bg-background shadow-xl w-10 h-10 rounded-full border-4 border-accent-primary flex-shrink-0">
                        <h1 class="mx-auto font-semibold text-lg text-text-main"><%= data.education.length - index %></h1>
                    </div>
                    
                    <div class="order-1 bg-card rounded-xl shadow-xl w-5/12 px-6 py-6 border border-border hover:border-accent-primary/50 transition-colors group">
                        
                        <!-- Header with Institution Image (placeholder) -->
                        <div class="h-32 -mx-6 -mt-6 mb-6 rounded-t-xl overflow-hidden relative">
                            <div class="absolute inset-0 bg-secondary/40 group-hover:bg-transparent transition-colors z-10"></div>
                            <img src="<%= edu.image %>" alt="<%= edu.institution %>" class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-500" onerror="this.src='https://images.unsplash.com/photo-1541339907198-e08756dedf3f?w=600&h=300&fit=crop'">
                        </div>

                        <div class="mb-2 flex items-center justify-between flex-wrap gap-2">
                            <span class="text-accent-primary text-sm font-semibold tracking-wide uppercase"><%= edu.duration %></span>
                            <span class="bg-secondary px-3 py-1 rounded-full text-xs font-medium text-text-main"><%= edu.score %></span>
                        </div>
                        
                        <h3 class="font-poppins font-bold text-xl text-text-main mb-1"><%= edu.degree %></h3>
                        <h4 class="text-text-muted font-medium mb-4"><%= edu.institution %></h4>
                        
                        <p class="text-sm leading-relaxed text-text-muted">
                            <%= edu.description %>
                        </p>
                    </div>
                </div>
            <% }) %>
        </div>

    </div>
</section>
