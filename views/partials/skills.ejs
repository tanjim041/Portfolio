<section id="skills" class="py-24 bg-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16" data-aos="fade-up">
            <h2 class="font-poppins text-3xl md:text-5xl font-bold text-text-main mb-4">Technical <span class="text-accent-primary">Skills</span></h2>
            <div class="w-24 h-1 bg-gradient-to-r from-accent-primary to-transparent mx-auto rounded-full mb-6"></div>
            <p class="text-text-muted max-w-2xl mx-auto">Technologies and core competencies I have acquired throughout my academic journey and personal projects.</p>
        </div>

        <!-- Hard Skills -->
        <div class="mb-16">
            <h3 class="text-2xl font-poppins font-semibold mb-8 text-center text-text-main" data-aos="fade-up">Hard Skills</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-4 md:gap-6">
                <% data.skills.hard.forEach((skill, index) => { %>
                    <div class="bg-card border border-border rounded-xl p-6 flex flex-col items-center justify-center gap-3 hover:-translate-y-2 hover:border-accent-primary hover:box-glow transition-all duration-300 group" data-aos="zoom-in" data-aos-delay="<%= index * 50 %>">
                        <div class="w-12 h-12 rounded-full bg-secondary flex items-center justify-center text-accent-primary group-hover:bg-accent-primary group-hover:text-background transition-colors duration-300">
                            <i data-lucide="code-2" class="w-6 h-6"></i>
                        </div>
                        <h4 class="font-medium text-text-main text-center"><%= skill %></h4>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Soft Skills -->
        <div>
            <h3 class="text-2xl font-poppins font-semibold mb-8 text-center text-text-main" data-aos="fade-up">Soft Skills</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-4 md:gap-6">
                <% data.skills.soft.forEach((skill, index) => { %>
                    <div class="bg-card border border-border rounded-xl p-6 flex flex-col items-center justify-center gap-3 hover:-translate-y-2 hover:border-accent-secondary hover:shadow-[0_0_20px_rgba(34,211,238,0.2)] transition-all duration-300 group" data-aos="zoom-in" data-aos-delay="<%= index * 50 %>">
                        <div class="w-12 h-12 rounded-full bg-secondary flex items-center justify-center text-accent-secondary group-hover:bg-accent-secondary group-hover:text-background transition-colors duration-300">
                            <i data-lucide="lightbulb" class="w-6 h-6"></i>
                        </div>
                        <h4 class="font-medium text-text-main text-center"><%= skill %></h4>
                    </div>
                <% }) %>
            </div>
        </div>

    </div>
</section>
