<section id="home" class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
    <!-- Particles Container -->
    <div id="particles-js"></div>
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-background/20 via-background/60 to-background pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
        
        <p class="text-accent-primary font-medium tracking-wide uppercase mb-4" data-aos="fade-down" data-aos-duration="1000">
            Hello, World! I am
        </p>
        
        <h1 class="font-poppins text-5xl md:text-7xl font-bold tracking-tight mb-4 text-text-main" data-aos="zoom-in" data-aos-duration="1200">
            <%= data.personal.name %>
        </h1>
        
        <h2 class="text-xl md:text-3xl text-text-muted font-light mb-8" data-aos="fade-up" data-aos-duration="1400" data-aos-delay="200">
            <%= data.personal.subtitle %>
        </h2>
        
        <!-- Typing Animation -->
        <div class="h-10 mb-12" data-aos="fade-up" data-aos-duration="1400" data-aos-delay="400">
            <div class="inline-flex items-center text-xl md:text-2xl font-semibold text-accent-secondary">
                <span class="mr-2">&gt;</span>
                <span id="typed-text" class="border-r-2 border-accent-secondary pr-1"></span>
            </div>
            <script>
                // Store titles in global scope for main.js to use
                window.typedTitles = <%- JSON.stringify(data.personal.titles) %>;
            </script>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-wrap justify-center gap-4" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="600">
            <a href="#cv" class="px-8 py-3 bg-accent-primary text-background font-semibold rounded-full hover:bg-accent-secondary hover-glow transition-all duration-300 flex items-center gap-2">
                <i data-lucide="download" class="w-5 h-5"></i> Download CV
            </a>
            <a href="#contact" class="px-8 py-3 bg-card border border-border text-text-main font-semibold rounded-full hover:bg-secondary hover:border-accent-primary/50 transition-all duration-300 flex items-center gap-2">
                <i data-lucide="mail" class="w-5 h-5"></i> Contact Me
            </a>
        </div>
        
        <!-- Social Links -->
        <div class="mt-12 flex space-x-6" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="800">
            <% data.socials.forEach(social => { %>
                <a href="<%= social.link %>" target="_blank" class="text-text-muted hover:text-accent-primary transition-colors hover:-translate-y-1 transform duration-300">
                    <i data-lucide="<%= social.icon %>" class="w-6 h-6"></i>
                    <span class="sr-only"><%= social.platform %></span>
                </a>
            <% }) %>
        </div>
        
        <!-- Scroll Indicator -->
        <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce">
            <a href="#about" class="text-text-muted hover:text-accent-primary transition-colors">
                <i data-lucide="chevrons-down" class="w-8 h-8"></i>
            </a>
        </div>
    </div>
</section>
