<section id="cv" class="py-24 relative overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent-primary/5 rounded-full filter blur-3xl -z-10"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent-secondary/5 rounded-full filter blur-3xl -z-10"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12" data-aos="fade-up">
            <h2 class="font-poppins text-3xl md:text-5xl font-bold text-text-main mb-4">Curriculum <span class="text-accent-primary">Vitae</span></h2>
            <div class="w-24 h-1 bg-gradient-to-r from-accent-primary to-transparent mx-auto rounded-full mb-6"></div>
            <p class="text-text-muted max-w-2xl mx-auto">View my detailed resume below or download it for later reference.</p>
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-center gap-4 mb-8" data-aos="fade-up" data-aos-delay="100">
            <a href="./public/cv/Tanjim_CV.pdf" download class="px-6 py-2 bg-accent-primary text-background font-medium rounded-lg hover:bg-accent-secondary hover-glow transition-all duration-300 flex items-center gap-2">
                <i data-lucide="download" class="w-5 h-5"></i> Download PDF
            </a>
            <a href="./public/cv/Tanjim_CV.pdf" target="_blank" class="px-6 py-2 bg-card border border-border text-text-main font-medium rounded-lg hover:bg-secondary hover:border-accent-primary/50 transition-all duration-300 flex items-center gap-2">
                <i data-lucide="external-link" class="w-5 h-5"></i> Open in New Tab
            </a>
        </div>

        <!-- PDF Viewer -->
        <div class="w-full bg-card border border-border rounded-2xl shadow-2xl overflow-hidden h-[600px] md:h-[800px] relative" data-aos="fade-up" data-aos-delay="200">
            <!-- Fallback if PDF cannot be rendered -->
            <div class="absolute inset-0 flex flex-col items-center justify-center text-text-muted p-8 text-center -z-10">
                <i data-lucide="file-text" class="w-16 h-16 mb-4 opacity-50"></i>
                <p>If the PDF does not display, you can download it using the button above.</p>
            </div>
            
            <iframe src="./public/cv/Tanjim_CV.pdf#toolbar=0&view=FitH" width="100%" height="100%" class="border-0 bg-white" title="CV Viewer"></iframe>
        </div>

    </div>
</section>
